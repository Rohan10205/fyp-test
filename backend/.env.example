# Copy this file to .env and fill in the values before starting the server.

# Port the API server will listen on
PORT=3000

# A long, random secret used to sign JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED: Replace REPLACE_ME with a real secret. Leaving it as-is will prevent the server from starting.
JWT_SECRET=REPLACE_ME

# Absolute or relative path to the SQLite database file.
# Defaults to ./db/vaultword.db if not set.
# DB_PATH=./db/vaultword.db

# Comma-separated list of allowed CORS origins (e.g. your Chrome extension ID).
# Use * to allow all origins during development.
# Example: chrome-extension://abcdefghijklmnopqrstuvwxyzabcdef
# ALLOWED_ORIGINS=*
